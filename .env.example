# Required: MapTiler API key for satellite + terrain tiles.
# Create a free account at https://www.maptiler.com/ and paste your key below.
MAPTILER_KEY=your_key_here

# Optional: web server port (default 8080)
# PORT=8080

# Optional: days to keep finished job artifacts in output/jobs/ before they
# are purged on server start. Set to 0 to disable. Default 30.
# JOB_TTL_DAYS=30
